{
  "name": "screenshot-maschine-3000",
  "version": "1.0.0",
  "description": "Monitor WhatsApp Web and screenshot on target contact messages",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "monitor": "node monitor.js",
    "check": "node --check monitor.js && node --check electron/main.js && node --check electron/preload.js && node --check electron/renderer.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.screenshotmaschine3000.app",
    "productName": "Screenshot Maschine 3000",
    "files": [
      "electron/**/*",
      "monitor.js",
      ".env.example",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asarUnpack": [
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-core/**/*"
    ]
  }
}
