# Required: set either CONTACT ID or CONTACT NAME.
# Best reliability: use TARGET_CONTACT_ID in WhatsApp JID format (e.g. 4917612345678@c.us).
# If you provide only a plain phone number, the script will convert it to @c.us automatically.
TARGET_CONTACT_ID=

# Optional fallback: exact contact/chat name match (case-insensitive).
TARGET_CONTACT_NAME=

# Optional settings
SCREENSHOT_DIR=./screenshots
LOCAL_AUTH_PATH=./.wwebjs_auth
HEADLESS=false
FULL_PAGE_SCREENSHOT=true
AUTO_OPEN_CHAT_BEFORE_SCREENSHOT=true
MESSAGE_RENDER_WAIT_MS=1200
DEBUG_FOCUS=false
RECONNECT_BASE_MS=5000
RECONNECT_MAX_MS=120000
LOG_TO_FILE=true
LOG_FILE=./logs/monitor.log
